{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/push-send?type=morning&cron=1",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/push-send?type=training&cron=1",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/push-send?type=nutrition&cron=1",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/push-send?type=skincare&cron=1",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/push-send?type=reminders&cron=1",
      "schedule": "0 13 * * *"
    }
  ]
}
